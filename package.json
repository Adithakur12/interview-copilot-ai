{
  "name": "interview-copilot-ai",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix src\"",
    "dev:backend": "npm run dev --prefix server",
    "dev:frontend": "npm run dev --prefix src",
    "build": "npm run build --prefix src",
    "start": "npm run start --prefix server",
    "test": "node --test server/tests/*.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
